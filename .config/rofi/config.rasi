configuration {
	modi: "combi,window,drun,org:~/.local/bin/rofi-org-mode.sh,buku:~/.local/bin/rofi-buku-mode.sh,keyword:~/.local/bin/rofi-keyword-mode.sh";
	width: 800;
	lines: 20;
	font: "PragmataPro Mono Liga 12";
	combi-modi: "keyword,org,window,drun";
	separator-style: "none";
	hide-scrollbar: true;
	display-window: "WS";
	display-drun: "Run";
	display-combi: "";
  display-org: "Open";
}

@import "/home/vita/.config/rofi/themes/solarized_custom.rasi"
